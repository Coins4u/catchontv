# Copy this file to `.env.local` (recommended) or `.env` — Next.js does NOT read `.env.example`.
#
# Hostinger SMTP (SSL on port 465):
#   SMTP_SECURE=true  (required for port 465)

SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=billing@catchontvapp.com
SMTP_PASS=your_mailbox_password_here
SMTP_FROM="Catchon TV <billing@catchontvapp.com>"

# Where you receive the "NEW FORM FILLED" notifications
ADMIN_EMAIL=your-personal-email@example.com

# Optional: canonical site URL for email footer links (Refund / Terms)
# NEXT_PUBLIC_SITE_URL=https://catchontvapp.com
